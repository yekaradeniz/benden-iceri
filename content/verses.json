    "moods": ["tefekkür", "ic-dunya", "halvet"],
    "format": "C",
    "caption": "dilin ile gönlün ile — Onbir Esas'tan 🌿\n\n#nakşbend #askyolculugu",
    "verified": true
  },
  {
